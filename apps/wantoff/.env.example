NEXT_PUBLIC_API_URL=http://localhost:3000

# Wallet mode: "standalone" (default) uses an injected browser wallet (MetaMask
# on Gnosis Chain). "embedded" uses @aboutcircles/miniapp-sdk for running inside
# the Circles host app (e.g. Circles Garage). See docs/wantoff-app-plan.md §9.
NEXT_PUBLIC_WALLET_MODE=standalone
