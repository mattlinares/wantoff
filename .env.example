# Used by docker-compose (local + prod) to configure the Postgres container
# and build the backend's DATABASE_URL.
POSTGRES_USER=mealmate
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mealmate
JWT_SECRET=change-me-to-a-random-secret

# Mailer: if SMTP_HOST is unset, emails are logged to the console instead of sent.
MAIL_FROM=Mealmate <no-reply@mealmate.local>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=change-me
